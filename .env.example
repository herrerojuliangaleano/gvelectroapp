# Seguridad principal
APP_ENABLED=true
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-clave
AUTH_SECRET=cambiar-este-secreto-largo-y-random

# CORS local/despliegue
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Persistencia
STORAGE_DIR=/app/storage
JOB_WORKERS=2
MAX_RECENT_JOBS=100

# Producción opcional: pegar el JSON completo del OAuth client como string.
# En local es más cómodo usar backend/secrets/credentials.local.json
# GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"..."}}

# Produccion opcional: token OAuth generado localmente con backend/scripts/google_oauth_bootstrap.py
# Copiar el contenido completo de backend/storage/secrets/token.json como string JSON.
# GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"..."}
